# 自动检测文本文件并规范化行结束符
* text=auto

# 源代码文件使用 LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# 配置文件
*.config.js text eol=lf
*.config.ts text eol=lf

# Shell 脚本必须使用 LF
*.sh text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.webm binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary